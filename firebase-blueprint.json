{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "savedVideoIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["uid", "email"]
    },
    "Donation": {
      "title": "Donation Record",
      "description": "Record of a user's donation",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Zakat", "Sadaqah", "Emergency Relief", "General"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] }
      },
      "required": ["uid", "amount", "category", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "User donation records"
    }
  }
}
